{# Executive PDF report for a single completed backtest run. #}
{# Mirrors the analytical-report visual language so the two PDFs feel #}
{# like one product. #}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Backtest {{ run.id[:8] }} — {{ run.strategy_name or run.strategy_slug or 'unknown' }}</title>
  <style>
    @page {
      size: Letter;
      margin: 0.85in 0.75in 0.85in 0.75in;
      @top-left {
        content: "Homerun · Backtest Report";
        font-size: 8.5pt;
        color: #6b7280;
      }
      @top-right {
        content: "Run {{ run.id[:8] }}";
        font-size: 8.5pt;
        color: #6b7280;
      }
      @bottom-right {
        content: counter(page) " of " counter(pages);
        font-size: 8.5pt;
        color: #6b7280;
      }
    }

    body {
      font-family: "Iowan Old Style", "Palatino", Georgia, serif;
      color: #111827;
      font-size: 10pt;
      line-height: 1.5;
    }
    .sans { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif; }
    .mono { font-family: "SF Mono", "Cascadia Code", Consolas, monospace; font-size: 8.5pt; }

    /* ── Hero ─────────────────────────────────────────── */
    .hero { padding-bottom: 14pt; border-bottom: 2px solid #111827; }
    .hero .label { font-family: -apple-system, sans-serif;
                   font-size: 9pt; letter-spacing: 0.18em;
                   text-transform: uppercase; color: #6b7280; }
    .hero h1 { font-size: 26pt; line-height: 1.15; margin: 6pt 0 2pt;
               font-weight: 700; }
    .hero .strat { font-size: 14pt; line-height: 1.45; color: #1f2937;
                   margin-top: 2pt; }
    .hero .meta { margin-top: 8pt; font-size: 9pt; color: #6b7280;
                  font-family: -apple-system, sans-serif; }
    .hero .meta .pill { display: inline-block; padding: 1pt 6pt;
                        background: #f3f4f6; border-radius: 9pt;
                        margin-right: 6pt; }
    .hero .meta .pill.ok { background: #ecfdf5; color: #065f46; }
    .hero .meta .pill.warn { background: #fef3c7; color: #92400e; }
    .hero .meta .pill.bad { background: #fee2e2; color: #991b1b; }

    /* ── Headline metric grid ──────────────────────────── */
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6pt;
      margin: 10pt 0;
    }
    .metric {
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      padding: 8pt 10pt;
    }
    .metric .l {
      font-family: -apple-system, sans-serif;
      font-size: 8pt;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #6b7280;
    }
    .metric .v { font-size: 16pt; font-weight: 700; line-height: 1.2;
                 margin-top: 2pt; }
    .metric .v.pos { color: #047857; }
    .metric .v.neg { color: #b91c1c; }
    .metric .sub { font-size: 9pt; color: #6b7280; margin-top: 1pt; }

    /* ── Section headers ──────────────────────────────── */
    h2 { font-family: -apple-system, sans-serif;
         font-size: 9pt; letter-spacing: 0.18em;
         text-transform: uppercase; color: #6b7280;
         border-top: 1px solid #e5e7eb; padding-top: 14pt;
         margin-top: 18pt; margin-bottom: 8pt; }

    /* ── Tables / metric rows ──────────────────────────── */
    .metric-rows { width: 100%; border-collapse: collapse; }
    .metric-rows td { padding: 4pt 8pt; border-bottom: 1px solid #f3f4f6;
                      font-size: 10pt; }
    .metric-rows td.label { color: #6b7280; width: 40%;
                            font-family: -apple-system, sans-serif; }
    .metric-rows td.value { font-family: "SF Mono", monospace;
                            font-size: 10pt; text-align: right; width: 22%; }
    .metric-rows td.ci { color: #6b7280; font-family: "SF Mono", monospace;
                         font-size: 8.5pt; }

    /* Two-column layout for risk + tail blocks */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14pt;
    }

    /* ── Equity curve SVG container ───────────────────── */
    .equity-curve {
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      padding: 8pt;
      background: #fafafa;
    }
    .equity-curve .header {
      display: flex;
      justify-content: space-between;
      font-family: -apple-system, sans-serif;
      font-size: 9pt;
      color: #4b5563;
      margin-bottom: 4pt;
    }
    .equity-curve .header .ret.pos { color: #047857; font-weight: 600; }
    .equity-curve .header .ret.neg { color: #b91c1c; font-weight: 600; }

    /* ── Coverage banner ──────────────────────────────── */
    .coverage {
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      padding: 8pt 10pt;
      font-size: 9pt;
      color: #4b5563;
      font-family: -apple-system, sans-serif;
      margin-bottom: 12pt;
    }
    .coverage.high { border-color: #a7f3d0; background: #ecfdf5; color: #065f46; }
    .coverage.medium { border-color: #fcd34d; background: #fefce8; color: #92400e; }
    .coverage.low { border-color: #fca5a5; background: #fef2f2; color: #991b1b; }
    .coverage .heading { font-weight: 600; margin-right: 6pt; }
    .coverage .rec { margin-top: 4pt; font-size: 8.5pt; }

    /* ── Footer note ──────────────────────────────────── */
    .footnote { font-size: 8pt; color: #9ca3af; margin-top: 18pt;
                text-align: center; font-family: -apple-system, sans-serif; }

    /* Avoid awkward page breaks in the metric grid + equity curve */
    .metric-grid, .equity-curve, .two-col { page-break-inside: avoid; }

    /* ── Compact data tables (regime, fold runs, etc.) ─────────── */
    .data-table { width: 100%; border-collapse: collapse; font-size: 9pt; }
    .data-table th { font-family: -apple-system, sans-serif;
                     font-size: 7.5pt; letter-spacing: 0.06em;
                     text-transform: uppercase; color: #6b7280;
                     text-align: left; padding: 4pt 6pt;
                     border-bottom: 1px solid #e5e7eb; }
    .data-table td { padding: 3pt 6pt; border-bottom: 1px solid #f3f4f6;
                     font-family: "SF Mono", monospace; font-size: 8.5pt; }
    .data-table td.r { text-align: right; }
    .data-table td.pos { color: #047857; }
    .data-table td.neg { color: #b91c1c; }

    /* Quadrant / 4-up grids for regime + diagnostics */
    .quad { display: grid; grid-template-columns: 1fr 1fr;
            gap: 10pt; margin-top: 6pt; }
    .quad .panel { border: 1px solid #e5e7eb; border-radius: 5pt;
                   padding: 8pt; background: #fafafa; }
    .quad .panel h3 { font-family: -apple-system, sans-serif;
                      font-size: 8pt; letter-spacing: 0.1em;
                      text-transform: uppercase; color: #6b7280;
                      margin: 0 0 4pt; font-weight: 600; }

    /* Win-rate row in regime panels: bucket label, mini-bar, pct */
    .regime-row { display: grid;
                  grid-template-columns: 60pt 1fr 28pt;
                  gap: 4pt; align-items: center;
                  font-size: 8.5pt; padding: 1.5pt 0; }
    .regime-row .b { font-family: "SF Mono", monospace;
                     color: #4b5563; }
    .regime-row .bar { height: 4pt; background: #e5e7eb;
                       border-radius: 2pt; position: relative;
                       overflow: hidden; }
    .regime-row .bar .fill { position: absolute; left: 0; top: 0; bottom: 0; }
    .regime-row .bar .fill.good { background: #10b981; }
    .regime-row .bar .fill.warn { background: #f59e0b; }
    .regime-row .bar .fill.bad { background: #f43f5e; }
    .regime-row .v { font-family: "SF Mono", monospace;
                     text-align: right; font-size: 8.5pt; }

    /* Hazard ratio bars (Cox PH) — diverging from x=1.0 */
    .hr-row { display: grid;
              grid-template-columns: 90pt 1fr 36pt;
              gap: 4pt; align-items: center;
              font-size: 8.5pt; padding: 1.5pt 0; }
    .hr-row .l { color: #6b7280; font-family: -apple-system, sans-serif;
                 font-size: 8pt; }
    .hr-row .bar { height: 4pt; background: #f3f4f6;
                   border-radius: 2pt; position: relative; }
    .hr-row .bar .center { position: absolute; left: 50%; top: 0;
                            bottom: 0; width: 1px; background: #9ca3af; }
    .hr-row .bar .fill-pos { position: absolute; left: 50%; top: 0;
                             bottom: 0; background: #10b981;
                             opacity: 0.7; }
    .hr-row .bar .fill-neg { position: absolute; right: 50%; top: 0;
                             bottom: 0; background: #f43f5e;
                             opacity: 0.7; }
    .hr-row .v { font-family: "SF Mono", monospace;
                  text-align: right; font-size: 8.5pt; }

    /* Correlation heatmap cell coloring — lighter borders, smaller text */
    .corr-table { border-collapse: collapse; font-size: 7pt;
                  font-family: "SF Mono", monospace; margin-top: 6pt; }
    .corr-table th, .corr-table td {
      border: 1px solid #f3f4f6; padding: 0; width: 22pt; height: 22pt;
      text-align: center; vertical-align: middle;
    }
    .corr-table th { background: #fafafa; color: #6b7280;
                     font-size: 6.5pt; font-weight: 600; }

    /* Ensemble-band p10/p50/p90 row */
    .band-row { display: grid;
                grid-template-columns: 14pt 1fr 1fr 1fr;
                gap: 4pt; align-items: center;
                font-family: "SF Mono", monospace;
                font-size: 8.5pt; padding: 2pt 0;
                border-bottom: 1px solid #f3f4f6; }
    .band-row .idx { color: #9ca3af; }
    .band-row .cell { padding: 1pt 5pt; border-radius: 3pt;
                      text-align: center; }
    .band-row .cell.p10 { background: #fef2f2; color: #b91c1c; }
    .band-row .cell.p50 { background: #fefce8; color: #92400e; }
    .band-row .cell.p90 { background: #ecfdf5; color: #047857; }

    /* Counterfactual row */
    .cf-row { font-family: "SF Mono", monospace; font-size: 8pt;
              padding: 3pt 6pt; border-bottom: 1px solid #f3f4f6;
              display: grid;
              grid-template-columns: 1fr auto;
              gap: 6pt; align-items: baseline; }
    .cf-row .meta { color: #6b7280; font-size: 7.5pt; }
    .cf-row .pill { font-size: 7.5pt; padding: 1pt 5pt;
                    border-radius: 8pt; font-family: -apple-system, sans-serif; }
    .cf-row .pill.ok { background: #ecfdf5; color: #047857; }
    .cf-row .pill.warn { background: #fefce8; color: #92400e; }

    /* Drift severity tile */
    .drift-tile {
      border: 1px solid #e5e7eb; border-radius: 5pt;
      padding: 6pt 8pt; text-align: center;
    }
    .drift-tile .l { font-size: 7.5pt; color: #6b7280;
                     letter-spacing: 0.08em; text-transform: uppercase;
                     font-family: -apple-system, sans-serif; }
    .drift-tile .v { font-size: 14pt; font-weight: 700;
                     font-family: "SF Mono", monospace; margin-top: 2pt; }
    .drift-tile.stable .v { color: #047857; }
    .drift-tile.improved .v { color: #0369a1; }
    .drift-tile.degraded .v { color: #b91c1c; }
    .drift-tile.stale .v { color: #6b7280; }

    /* All sub-section blocks should avoid breaking mid-element */
    .quad, .data-table, .corr-table, .hr-row, .regime-row,
    .band-row, .cf-row, .drift-tile {
      page-break-inside: avoid;
    }

    h3 { font-family: -apple-system, sans-serif;
         font-size: 9pt; font-weight: 600; color: #374151;
         margin: 12pt 0 4pt; }
  </style>
</head>
<body>

{# ── Hero ─────────────────────────────────────────────────────── #}
<div class="hero">
  <div class="label">Backtest Run · {{ run.id[:8] }}</div>
  <h1>{{ run.strategy_name or run.strategy_slug or 'Unknown strategy' }}</h1>
  <div class="strat">
    {% if run.total_return_pct >= 0 %}
      Return <span style="color: #047857; font-weight: 700;">+{{ '%.2f' | format(run.total_return_pct) }}%</span>
      ({{ run.net_pnl_usd | money_signed }} on {{ run.initial_capital_usd | money }})
    {% else %}
      Return <span style="color: #b91c1c; font-weight: 700;">{{ '%.2f' | format(run.total_return_pct) }}%</span>
      ({{ run.net_pnl_usd | money_signed }} on {{ run.initial_capital_usd | money }})
    {% endif %}
  </div>
  <div class="meta">
    <span class="pill {{ 'ok' if run.status in ('completed','ok') else ('bad' if run.status == 'failed' else 'warn') }}">
      {{ run.status }}
    </span>
    {% if run.replay_source %}<span class="pill mono">replay: {{ run.replay_source }}</span>{% endif %}
    {% if run.discovery_mode %}<span class="pill mono">discovery: {{ run.discovery_mode }}</span>{% endif %}
    <span>started {{ run.started_at | humanize_dt }}</span>
    {% if run.completed_at %}<span>· completed {{ run.completed_at | humanize_dt }}</span>{% endif %}
    {% if run.total_time_ms %}<span>· {{ '%.1f' | format(run.total_time_ms / 1000.0) }}s</span>{% endif %}
  </div>
</div>

{# ── Data fidelity banner (when we have a rating) ──────────────── #}
{% if run.fidelity_rating %}
<div class="coverage
  {% if run.replay_source and run.replay_source.startswith('deltas') -%}high
  {%- elif run.fidelity_rating == 'high' -%}high
  {%- elif run.fidelity_rating == 'medium' -%}medium
  {%- else -%}low{%- endif %}">
  <span class="heading">
    {% if run.replay_source and run.replay_source.startswith('deltas') -%}
      Live-parity replay (delta book)
    {%- elif run.fidelity_rating == 'high' -%}
      Data fidelity: HIGH
    {%- elif run.fidelity_rating == 'medium' -%}
      Data fidelity: MEDIUM
    {%- else -%}
      Data fidelity: {{ run.fidelity_rating | upper }}
    {%- endif %}
  </span>
  {{ run.tokens_with_snapshots or 0 }}/{{ run.opp_tokens or 0 }} tokens with snapshots
  · median {{ '%.1f' | format(run.median_snaps_per_token_per_hour or 0) }}/hr snapshots
  · median {{ '%.1f' | format(run.median_deltas_per_token_per_hour or 0) }}/hr deltas
  {% if run.fidelity_recommendation %}
    <div class="rec">{{ run.fidelity_recommendation }}</div>
  {% endif %}
</div>
{% endif %}

{# ── Headline KPIs ─────────────────────────────────────────────── #}
<h2>Headline</h2>
<div class="metric-grid">
  <div class="metric">
    <div class="l">Return</div>
    <div class="v {{ 'pos' if run.total_return_pct >= 0 else 'neg' }}">
      {{ run.total_return_pct | pct_signed }}
    </div>
    <div class="sub">{{ run.net_pnl_usd | money_signed }} net</div>
  </div>
  <div class="metric">
    <div class="l">Sharpe</div>
    <div class="v {{ 'pos' if (run.sharpe.value or 0) >= 1.0 else ('neg' if (run.sharpe.value or 0) < 0 else '') }}">
      {% if run.sharpe.value is not none %}{{ '%.2f' | format(run.sharpe.value) }}{% else %}—{% endif %}
    </div>
    {% if run.sharpe.ci_low is not none and run.sharpe.ci_high is not none %}
    <div class="sub">ci [{{ '%.2f' | format(run.sharpe.ci_low) }}, {{ '%.2f' | format(run.sharpe.ci_high) }}]</div>
    {% endif %}
  </div>
  <div class="metric">
    <div class="l">Max drawdown</div>
    <div class="v {{ 'neg' if run.max_drawdown_pct < -10 else '' }}">
      {{ '%.2f' | format(run.max_drawdown_pct) }}%
    </div>
    <div class="sub">{{ run.max_drawdown_usd | money }}</div>
  </div>
  <div class="metric">
    <div class="l">Trades</div>
    <div class="v">{{ run.trade_count | int_thousands }}</div>
    <div class="sub">
      {{ run.total_fills | int_thousands }} fills · {{ run.cancelled_orders | int_thousands }} cancels
    </div>
  </div>
</div>

{# ── Equity curve (inline SVG so it's print-perfect) ──────────── #}
{% if run.equity_curve_sample and (run.equity_curve_sample | length) >= 2 %}
{% set _curve = run.equity_curve_sample %}
{% set _equities = _curve | map(attribute='equity_usd') | list %}
{% set _initial = _equities[0] %}
{% set _final = _equities[-1] %}
{% set _max_e = _equities | max %}
{% set _min_e = _equities | min %}
{% set _is_up = _final >= _initial %}
<h2>Equity curve</h2>
<div class="equity-curve">
  <div class="header">
    <span>{{ _initial | money }} → {{ _final | money }}</span>
    <span class="ret {{ 'pos' if _is_up else 'neg' }}">
      {{ ((_final - _initial) / _initial * 100) | pct_signed if _initial > 0 else '' }}
    </span>
    <span>{{ _curve | length }} samples</span>
  </div>
  {# Manual SVG renderer — geometry computed in template using a small #}
  {# trick: scale equity values into a 600×140 box.  We loop the array #}
  {# once to build the path string. #}
  {% set _w = 600 %}
  {% set _h = 140 %}
  {% set _padL = 4 %}
  {% set _padR = 4 %}
  {% set _padT = 6 %}
  {% set _padB = 6 %}
  {% set _innerW = _w - _padL - _padR %}
  {% set _innerH = _h - _padT - _padB %}
  {% set _range = (_max_e - _min_e) if (_max_e - _min_e) > 0.000001 else 0.000001 %}
  {% set _n = _curve | length %}
  {% set _color = '#10b981' if _is_up else '#f43f5e' %}
  {% set _pts = [] %}
  {% for p in _curve %}
    {% set _x = _padL + (loop.index0 / (_n - 1)) * _innerW %}
    {% set _y = _padT + (1 - (p.equity_usd - _min_e) / _range) * _innerH %}
    {% set _ = _pts.append('%s%.1f,%.1f' | format('M' if loop.first else 'L', _x, _y)) %}
  {% endfor %}
  {% set _baseline_y = _padT + (1 - (_initial - _min_e) / _range) * _innerH %}
  <svg viewBox="0 0 {{ _w }} {{ _h }}" preserveAspectRatio="none"
       width="100%" height="140" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="bt-eq-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="{{ _color }}" stop-opacity="0.32"/>
        <stop offset="100%" stop-color="{{ _color }}" stop-opacity="0"/>
      </linearGradient>
    </defs>
    {# Baseline at initial capital #}
    <line x1="{{ _padL }}" y1="{{ '%.1f' | format(_baseline_y) }}"
          x2="{{ _w - _padR }}" y2="{{ '%.1f' | format(_baseline_y) }}"
          stroke="#9ca3af" stroke-opacity="0.5" stroke-dasharray="4,3" stroke-width="0.8"/>
    {# Filled area #}
    <path d="{{ _pts | join(' ') }} L{{ '%.1f' | format(_padL + _innerW) }},{{ '%.1f' | format(_padT + _innerH) }} L{{ '%.1f' | format(_padL) }},{{ '%.1f' | format(_padT + _innerH) }} Z"
          fill="url(#bt-eq-grad)"/>
    {# Equity line #}
    <path d="{{ _pts | join(' ') }}" fill="none" stroke="{{ _color }}"
          stroke-width="1.5" stroke-linejoin="round"/>
  </svg>
</div>
{% endif %}

{# ── Risk + Tail risk side-by-side ────────────────────────────── #}
<h2>Risk-adjusted &amp; Tail-risk metrics</h2>
<div class="two-col">
  <div>
    <table class="metric-rows">
      <tr><td class="label">Sharpe</td>
          <td class="value">{% if run.sharpe.value is not none %}{{ '%.3f' | format(run.sharpe.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.sharpe.ci_low is not none %}ci [{{ '%.3f' | format(run.sharpe.ci_low) }}, {{ '%.3f' | format(run.sharpe.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label">Sortino</td>
          <td class="value">{% if run.sortino.value is not none %}{{ '%.3f' | format(run.sortino.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.sortino.ci_low is not none %}ci [{{ '%.3f' | format(run.sortino.ci_low) }}, {{ '%.3f' | format(run.sortino.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label">Calmar</td>
          <td class="value">{% if run.calmar.value is not none %}{{ '%.3f' | format(run.calmar.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.calmar.ci_low is not none %}ci [{{ '%.3f' | format(run.calmar.ci_low) }}, {{ '%.3f' | format(run.calmar.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label">Hit rate</td>
          <td class="value">{% if run.hit_rate.value is not none %}{{ '%.3f' | format(run.hit_rate.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.hit_rate.ci_low is not none %}ci [{{ '%.3f' | format(run.hit_rate.ci_low) }}, {{ '%.3f' | format(run.hit_rate.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label">Profit factor</td>
          <td class="value">{% if run.profit_factor.value is not none %}{{ '%.3f' | format(run.profit_factor.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.profit_factor.ci_low is not none %}ci [{{ '%.3f' | format(run.profit_factor.ci_low) }}, {{ '%.3f' | format(run.profit_factor.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label">Expectancy ($)</td>
          <td class="value">{% if run.expectancy_usd.value is not none %}{{ '%.3f' | format(run.expectancy_usd.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.expectancy_usd.ci_low is not none %}ci [{{ '%.3f' | format(run.expectancy_usd.ci_low) }}, {{ '%.3f' | format(run.expectancy_usd.ci_high) }}]{% endif %}</td></tr>
    </table>
  </div>
  <div>
    <table class="metric-rows">
      <tr><td class="label">ES 5% (CVaR)</td>
          <td class="value">{% if run.expected_shortfall_5pct.value is not none %}{{ '%.4f' | format(run.expected_shortfall_5pct.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.expected_shortfall_5pct.ci_low is not none %}ci [{{ '%.4f' | format(run.expected_shortfall_5pct.ci_low) }}, {{ '%.4f' | format(run.expected_shortfall_5pct.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label">ES 1% (CVaR)</td>
          <td class="value">{% if run.expected_shortfall_1pct.value is not none %}{{ '%.4f' | format(run.expected_shortfall_1pct.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.expected_shortfall_1pct.ci_low is not none %}ci [{{ '%.4f' | format(run.expected_shortfall_1pct.ci_low) }}, {{ '%.4f' | format(run.expected_shortfall_1pct.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label">Tail ratio</td>
          <td class="value">{% if run.tail_ratio.value is not none %}{{ '%.3f' | format(run.tail_ratio.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.tail_ratio.ci_low is not none %}ci [{{ '%.3f' | format(run.tail_ratio.ci_low) }}, {{ '%.3f' | format(run.tail_ratio.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label">Gain-to-pain</td>
          <td class="value">{% if run.gain_to_pain.value is not none %}{{ '%.3f' | format(run.gain_to_pain.value) }}{% else %}—{% endif %}</td>
          <td class="ci">{% if run.gain_to_pain.ci_low is not none %}ci [{{ '%.3f' | format(run.gain_to_pain.ci_low) }}, {{ '%.3f' | format(run.gain_to_pain.ci_high) }}]{% endif %}</td></tr>
      <tr><td class="label" style="border-top: 1pt solid #e5e7eb; padding-top: 8pt;" colspan="3">
        <span style="font-size: 8pt; color: #9ca3af;">
          ES = mean of worst-tail returns. Tail ratio &lt; 1 ⇒ downside-heavy payouts.
        </span>
      </td></tr>
    </table>
  </div>
</div>

{# ── Deflated Sharpe (López de Prado) ──────────────────────────── #}
{% if run.probabilistic_sharpe is not none %}
<h2>Deflated Sharpe (López de Prado)</h2>
<div class="two-col">
  <div class="metric">
    <div class="l">P(true SR &gt; 0)</div>
    <div class="v {{ 'pos' if run.probabilistic_sharpe >= 0.95 else ('neg' if run.probabilistic_sharpe < 0.7 else '') }}">
      {{ '%.1f' | format(run.probabilistic_sharpe * 100) }}%
    </div>
  </div>
  <div class="metric">
    <div class="l">P(SR &gt; SR₀ overfit)</div>
    <div class="v {{ 'pos' if run.deflated_sharpe_value >= 0.95 else ('neg' if run.deflated_sharpe_value < 0.7 else '') }}">
      {{ '%.1f' | format((run.deflated_sharpe_value or 0) * 100) }}%
    </div>
    <div class="sub">{{ run.n_trials or 1 }} trial(s) · SR₀ {{ '%.2f' | format(run.sr_zero or 0) }}</div>
  </div>
</div>
{% endif %}

{# ── Trade economics ──────────────────────────────────────────── #}
<h2>Trade economics</h2>
<div class="metric-grid">
  <div class="metric">
    <div class="l">Avg win</div>
    <div class="v pos">{{ run.avg_win_usd | money }}</div>
  </div>
  <div class="metric">
    <div class="l">Avg loss</div>
    <div class="v neg">{{ run.avg_loss_usd | money }}</div>
  </div>
  <div class="metric">
    <div class="l">Total fees</div>
    <div class="v">{{ run.fees_paid_usd | money }}</div>
  </div>
  <div class="metric">
    <div class="l">Final equity</div>
    <div class="v {{ 'pos' if run.net_pnl_usd >= 0 else 'neg' }}">
      {{ run.final_equity_usd | money }}
    </div>
  </div>
</div>

{# ════════════════ ROBUSTNESS ════════════════════════════════ #}

{# ── Trade-order Monte Carlo (full block) ─────────────────────── #}
{% if run.tom_realized_sharpe is not none and not run.tom_skipped_reason %}
<h2>Trade-order Monte Carlo</h2>
<div class="metric-grid">
  <div class="metric">
    <div class="l">Realized SR</div>
    <div class="v">{{ '%.2f' | format(run.tom_realized_sharpe) }}</div>
    <div class="sub">{{ run.tom_n_trades or 0 }} trades</div>
  </div>
  <div class="metric">
    <div class="l">Shuffle median</div>
    <div class="v">{{ '%.2f' | format(run.tom_distribution.get('p50') or 0) }}</div>
    <div class="sub">p5 {{ '%.2f' | format(run.tom_distribution.get('p5') or 0) }} · p95 {{ '%.2f' | format(run.tom_distribution.get('p95') or 0) }}</div>
  </div>
  <div class="metric">
    <div class="l">Stdev</div>
    <div class="v">{{ '%.2f' | format(run.tom_distribution.get('stdev') or 0) }}</div>
    <div class="sub">{{ run.tom_n_resamples or 0 }} resamples</div>
  </div>
  <div class="metric">
    <div class="l">Position</div>
    <div class="v {% if run.tom_interpretation == 'sequence-driven' %}neg{% else %}pos{% endif %}">
      {% if run.tom_position_pct is not none %}{{ '%.0f' | format(run.tom_position_pct) }}th{% else %}—{% endif %}
    </div>
    <div class="sub">{{ run.tom_interpretation or '' }}</div>
  </div>
</div>
<p style="font-size: 8.5pt; color: #6b7280; margin-top: 4pt;">
  Shuffles the trade order N times and recomputes Sharpe.  A position
  &lt; 50th percentile means the realized SR was unlucky in ordering;
  &gt; 50th means it benefited.  Interpretation labels:
  ``sequence-driven`` = Sharpe depends materially on ordering (fragile);
  ``order-robust`` = Sharpe is stable across permutations.
</p>
{% endif %}

{# ── Regime decomposition (4-quadrant) ────────────────────────── #}
{% if run.regime_by_hour or run.regime_by_dow or run.regime_by_ttr or run.regime_by_size %}
<h2>Regime decomposition</h2>
<p style="font-size: 8.5pt; color: #6b7280; margin: -4pt 0 4pt;">
  Win-rate broken out by hour-of-day, day-of-week, time-to-revenue
  bucket, and size bucket.  Bars scale to per-bucket sample size.
</p>
<div class="quad">
  {% set _regimes = [
    ('By hour of day', run.regime_by_hour),
    ('By day of week', run.regime_by_dow),
    ('By time to revenue', run.regime_by_ttr),
    ('By trade size', run.regime_by_size),
  ] %}
  {% for title, rows in _regimes %}
    {% if rows %}
    <div class="panel">
      <h3>{{ title }}</h3>
      {% set _max_n = (rows | map(attribute='n') | max) or 1 %}
      {% for r in rows | sort(attribute='n', reverse=True) %}
        {% set _winpct = (r.win_rate or 0) * 100 %}
        {% set _tone = 'good' if _winpct >= 60 else ('warn' if _winpct >= 40 else 'bad') %}
        {% set _w = (((r.n or 0) / _max_n) * 100) | round(0, 'floor') %}
        <div class="regime-row">
          <span class="b">{{ r.bucket }}</span>
          <span class="bar">
            <span class="fill {{ _tone }}" style="width: {{ _w }}%"></span>
          </span>
          <span class="v">{% if r.n and r.n >= 1 %}{{ _winpct | round(0) | int }}%{% else %}—{% endif %}</span>
        </div>
      {% endfor %}
    </div>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

{# ── Triangulation (live cross-mode comparison) ───────────────── #}
{% if triangulation %}
<h2>Triangulation: backtest vs shadow vs live</h2>
<div class="metric-grid" style="grid-template-columns: 1fr 1fr 1fr;">
  <div class="metric">
    <div class="l">Backtest PnL</div>
    <div class="v {{ 'pos' if run.net_pnl_usd >= 0 else 'neg' }}">
      {{ run.net_pnl_usd | money_signed }}
    </div>
    <div class="sub">{{ run.trade_count }} trades · {{ run.total_return_pct | pct_signed }}</div>
  </div>
  <div class="metric">
    <div class="l">Shadow PnL</div>
    <div class="v {{ 'pos' if (triangulation.shadow_realized_pnl_usd or 0) >= 0 else 'neg' }}">
      {{ triangulation.shadow_realized_pnl_usd | money_signed }}
    </div>
    <div class="sub">{{ triangulation.shadow_orders or 0 }} orders · {{ triangulation.shadow_filled or 0 }} filled</div>
  </div>
  <div class="metric">
    <div class="l">Live PnL</div>
    <div class="v {{ 'pos' if (triangulation.live_realized_pnl_usd or 0) >= 0 else 'neg' }}">
      {{ triangulation.live_realized_pnl_usd | money_signed }}
    </div>
    <div class="sub">{{ triangulation.live_orders or 0 }} orders · {{ triangulation.live_filled or 0 }} filled</div>
  </div>
</div>
<p style="font-size: 8.5pt; color: #6b7280; margin-top: 4pt;">
  {{ triangulation.window_days or 30 }}-day window.  Big divergence
  between any two columns ⇒ fill model is the prime suspect.  Aligned
  numbers ⇒ the strategy generalizes from backtest to live.
</p>
{% endif %}

{# ════════════════ EXECUTION QUALITY ════════════════════════════ #}

{# ── Ensemble bands (p10/p50/p90 sample) ──────────────────────── #}
{% if run.ensemble_band %}
<h2>Ensemble bands ({{ run.ensemble_band | length }}/{{ run.ensemble_total }} fills)</h2>
<p style="font-size: 8.5pt; color: #6b7280; margin: -4pt 0 4pt;">
  Each row simulates the same fill 100× under fill-model uncertainty
  and reports p10/p50/p90 outcome rates.  Cox PH–based when a model is
  loaded; heuristic otherwise.
</p>
{% for b in run.ensemble_band %}
<div class="band-row">
  <span class="idx">#{{ loop.index }}</span>
  <span class="cell p10">p10 {{ '%.1f' | format((b.pessimistic or 0) * 100) }}%</span>
  <span class="cell p50">p50 {{ '%.1f' | format((b.realistic or 0) * 100) }}%</span>
  <span class="cell p90">p90 {{ '%.1f' | format((b.optimistic or 0) * 100) }}%</span>
</div>
{% endfor %}
{% endif %}

{# ── Counterfactual replays ──────────────────────────────────── #}
{% if run.counterfactuals %}
<h2>Counterfactual replays ({{ run.counterfactuals | length }}/{{ run.counterfactuals_total }} samples)</h2>
<p style="font-size: 8.5pt; color: #6b7280; margin: -4pt 0 4pt;">
  Sample of fills replayed against actual book state to validate the
  matcher would have filled the same way.
</p>
{% for row in run.counterfactuals %}
{% set _r = row.result %}
{% set _ratio = (_r.filled_shares / row.fill.size) if (row.fill and row.fill.size and row.fill.size > 0) else 0 %}
{% set _expired = _r.expired %}
<div class="cf-row">
  <span>
    <strong>{{ row.fill.side | upper }}</strong>
    ${{ '%.4f' | format(row.fill.price or 0) }} × {{ '%.1f' | format(row.fill.size or 0) }}
    <span class="meta">
      queue {{ '%.0f' | format(_r.final_queue_ahead or 0) }} ·
      trades-ahead {{ '%.0f' | format(_r.trades_ahead_observed or 0) }} ·
      cancels-ahead {{ '%.0f' | format(_r.cancels_ahead_observed or 0) }}
      {% if _r.time_to_fill_seconds is not none %}· ttf {{ '%.1f' | format(_r.time_to_fill_seconds) }}s{% endif %}
    </span>
  </span>
  <span class="pill {{ 'warn' if _expired else 'ok' }}">
    {% if _expired %}expired{% else %}filled {{ (_ratio * 100) | round(0) | int }}%{% endif %}
  </span>
</div>
{% endfor %}
{% endif %}

{# ── Partial fill aggregates (full block) ──────────────────────── #}
{% if run.n_orders %}
<h2>Partial fill aggregates</h2>
<div class="metric-grid">
  <div class="metric">
    <div class="l">Instant fill rate</div>
    <div class="v {% if (run.instant_fill_rate or 0) >= 0.7 %}pos{% elif (run.instant_fill_rate or 0) < 0.4 %}neg{% endif %}">
      {{ ((run.instant_fill_rate or 0) * 100) | round(0) | int }}%
    </div>
    <div class="sub">{{ run.n_instant_fills or 0 }} of {{ run.n_orders }} orders</div>
  </div>
  <div class="metric">
    <div class="l">Avg children</div>
    <div class="v">{{ '%.2f' | format(run.mean_children_per_order or 0) }}</div>
    <div class="sub">max {{ run.max_children_per_order or 0 }}</div>
  </div>
  <div class="metric">
    <div class="l">Intra-order span</div>
    <div class="v">
      {% if (run.mean_intra_order_seconds or 0) > 0 %}
        {{ '%.1f' | format(run.mean_intra_order_seconds) }}s
      {% else %}—{% endif %}
    </div>
    <div class="sub">first → last child</div>
  </div>
  <div class="metric">
    <div class="l">VWAP dispersion</div>
    <div class="v {% if (run.mean_vwap_dispersion_bps or 0) > 50 %}neg{% endif %}">
      {{ '%.1f' | format(run.mean_vwap_dispersion_bps or 0) }} bps
    </div>
    <div class="sub">across child fills</div>
  </div>
</div>
{% if run.child_count_distribution and (run.child_count_distribution | length) > 1 %}
<h3>Child-count distribution</h3>
<table class="data-table">
  <thead><tr><th>Children</th><th class="r">Orders</th><th class="r">% of orders</th></tr></thead>
  <tbody>
    {% for d in run.child_count_distribution %}
    {% set _pct = (d.n_orders / run.n_orders * 100) if run.n_orders else 0 %}
    <tr>
      <td>{{ d.children }}</td>
      <td class="r">{{ d.n_orders }}</td>
      <td class="r">{{ '%.1f' | format(_pct) }}%</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
{% endif %}

{# ── Data quality (acceptance, gaps, drops, rejects) ──────────── #}
{% if run.dq_total_attempts %}
<h2>Data quality</h2>
<div class="metric-grid">
  <div class="metric">
    <div class="l">Accept rate</div>
    <div class="v {% if (run.dq_accept_rate or 1) >= 0.99 %}pos{% elif (run.dq_accept_rate or 1) < 0.95 %}neg{% endif %}">
      {{ '%.1f' | format((run.dq_accept_rate or 0) * 100) }}%
    </div>
    <div class="sub">{{ '{:,}'.format(run.dq_accepted_books or 0) }} / {{ '{:,}'.format(run.dq_total_attempts or 0) }}</div>
  </div>
  <div class="metric">
    <div class="l">Sequence gaps</div>
    <div class="v">{{ '{:,}'.format(run.dq_sequence_gaps or 0) }}</div>
    <div class="sub">across {{ run.dq_tokens_tracked or 0 }} tokens</div>
  </div>
  <div class="metric">
    <div class="l">Queue dropped</div>
    <div class="v {% if (run.dq_queue_dropped or 0) > 0 %}neg{% endif %}">
      {{ '{:,}'.format(run.dq_queue_dropped or 0) }}
    </div>
    <div class="sub">snapshots discarded</div>
  </div>
  <div class="metric">
    <div class="l">Total rejects</div>
    <div class="v">
      {% set _total_rejects = (run.dq_rejects_by_reason.values() | sum) if run.dq_rejects_by_reason else 0 %}
      {{ '{:,}'.format(_total_rejects) }}
    </div>
    <div class="sub">all reasons combined</div>
  </div>
</div>
{% if run.dq_rejects_by_reason %}
{% set _has_rejects = run.dq_rejects_by_reason.values() | select | list | length > 0 %}
{% if _has_rejects %}
<h3>Rejects by reason</h3>
<table class="data-table">
  <thead><tr><th>Reason</th><th class="r">Count</th></tr></thead>
  <tbody>
    {% for reason, n in run.dq_rejects_by_reason.items() | sort(attribute='1', reverse=True) %}
    {% if n > 0 %}
    <tr>
      <td style="font-family: -apple-system, sans-serif;">{{ reason }}</td>
      <td class="r neg">{{ '{:,}'.format(n) }}</td>
    </tr>
    {% endif %}
    {% endfor %}
  </tbody>
</table>
{% endif %}
{% endif %}
{% endif %}

{# ── Fill model (Cox PH snapshot) ──────────────────────────────── #}
{% if run.fill_model_loaded %}
<h2>Fill model (Cox PH)</h2>
<div class="two-col">
  <div class="metric">
    <div class="l">C-index</div>
    <div class="v {% if (run.concordance_index or 0) > 0.62 %}pos{% elif (run.concordance_index or 0) <= 0.55 %}neg{% endif %}">
      {% if run.concordance_index is not none %}{{ '%.3f' | format(run.concordance_index) }}{% else %}—{% endif %}
    </div>
    <div class="sub">{{ run.fill_model_family }} · concordance vs random = 0.5</div>
  </div>
  <div class="metric">
    <div class="l">Training events</div>
    <div class="v">{{ '{:,}'.format(run.fill_model_n_events or 0) }}</div>
    <div class="sub">fills used to fit hazard ratios</div>
  </div>
</div>
{% if run.hazard_ratios %}
<h3>Top hazard ratios</h3>
<p style="font-size: 8.5pt; color: #6b7280; margin: -2pt 0 4pt;">
  HR &gt; 1 increases fill probability; HR &lt; 1 decreases.  Bars
  scale to |log₂(HR)|.  Top 8 by influence.
</p>
{% for h in run.hazard_ratios %}
{% set _is_pos = h.hr >= 1.0 %}
{% set _bar_pct = ((((h.hr | log2 | abs) if h.hr > 0 else 0) * 100) | round(0)) if false else 0 %}
<div class="hr-row">
  <span class="l">{{ h.covariate }}</span>
  <span class="bar">
    <span class="center"></span>
    {% if _is_pos %}
      <span class="fill-pos" style="width: {{ ((h.hr - 1.0) * 60) | round(0) | int | abs }}%; max-width: 50%;"></span>
    {% else %}
      <span class="fill-neg" style="width: {{ ((1.0 - h.hr) * 60) | round(0) | int | abs }}%; max-width: 50%;"></span>
    {% endif %}
  </span>
  <span class="v {% if _is_pos %}pos{% else %}neg{% endif %}">{{ '%.2f' | format(h.hr) }}×</span>
</div>
{% endfor %}
{% endif %}
{% endif %}

{# ── Latency distribution ─────────────────────────────────────── #}
{% if run.latency_p50_ms is not none %}
<h2>Latency distribution</h2>
<div class="metric-grid" style="grid-template-columns: 1fr 1fr 1fr;">
  <div class="metric">
    <div class="l">p50</div>
    <div class="v">{{ '%.0f' | format(run.latency_p50_ms or 0) }} ms</div>
  </div>
  <div class="metric">
    <div class="l">p95</div>
    <div class="v {% if (run.latency_p95_ms or 0) > 800 %}neg{% endif %}">
      {{ '%.0f' | format(run.latency_p95_ms or 0) }} ms
    </div>
  </div>
  <div class="metric">
    <div class="l">p99</div>
    <div class="v {% if (run.latency_p99_ms or 0) > 1500 %}neg{% endif %}">
      {{ '%.0f' | format(run.latency_p99_ms or 0) }} ms
    </div>
  </div>
</div>
<p style="font-size: 8.5pt; color: #6b7280; margin-top: 4pt;">
  {% if run.latency_sample_count and run.latency_sample_count > 0 %}
    Measured from {{ '{:,}'.format(run.latency_sample_count) }} live submits ·
    pessimistic {{ '%.0f' | format(run.latency_pessimistic_ms or 0) }} /
    realistic {{ '%.0f' | format(run.latency_realistic_ms or 0) }} /
    optimistic {{ '%.0f' | format(run.latency_optimistic_ms or 0) }} ms
  {% else %}
    Default percentiles — no live samples measured for this run.
  {% endif %}
</p>
{% endif %}

{# ════════════════ CROSS-STRATEGY ═══════════════════════════════ #}

{# ── Outcome netting (full block) ─────────────────────────────── #}
{% if run.gross_exposure_usd is not none %}
<h2>Outcome netting &amp; capital lockup</h2>
<div class="metric-grid">
  <div class="metric">
    <div class="l">Gross exposure</div>
    <div class="v">{{ run.gross_exposure_usd | money_compact }}</div>
    <div class="sub">all open contracts</div>
  </div>
  <div class="metric">
    <div class="l">Net exposure</div>
    <div class="v {% if (run.rebate_estimate_usd or 0) > 0 %}pos{% endif %}">
      {{ run.net_exposure_usd | money_compact }}
    </div>
    <div class="sub">
      {% if (run.rebate_estimate_usd or 0) > 0 %}
        rebate ≈ {{ run.rebate_estimate_usd | money_compact }}
      {% else %}
        no offsetting positions
      {% endif %}
    </div>
  </div>
  <div class="metric">
    <div class="l">Capital efficiency</div>
    <div class="v {% if (run.capital_efficiency_pct or 0) >= 20 %}pos{% endif %}">
      {% if run.capital_efficiency_pct is not none %}{{ '%.1f' | format(run.capital_efficiency_pct) }}%{% else %}—{% endif %}
    </div>
    <div class="sub">savings vs naïve</div>
  </div>
  <div class="metric">
    <div class="l">Locked capital</div>
    <div class="v">{{ run.locked_capital_usd | money_compact }}</div>
    <div class="sub">{{ run.open_positions or 0 }} open positions</div>
  </div>
</div>
{% if run.outcome_groups %}
<h3>Outcome groups</h3>
<div class="metric-grid" style="grid-template-columns: 1fr 1fr 1fr;">
  <div class="metric">
    <div class="l">Full coverage</div>
    <div class="v pos">{{ run.outcome_groups.get('full_coverage', 0) }}</div>
    <div class="sub">every outcome bought</div>
  </div>
  <div class="metric">
    <div class="l">Partial</div>
    <div class="v">{{ run.outcome_groups.get('partial', 0) }}</div>
    <div class="sub">some outcomes covered</div>
  </div>
  <div class="metric">
    <div class="l">Single</div>
    <div class="v">{{ run.outcome_groups.get('single', 0) }}</div>
    <div class="sub">one outcome only</div>
  </div>
</div>
{% endif %}
{% if run.avg_lockup_seconds is not none or run.max_lockup_seconds is not none %}
<table class="data-table" style="margin-top: 6pt;">
  <tr>
    <td style="font-family: -apple-system, sans-serif; color: #6b7280;">Avg lockup</td>
    <td class="r">
      {% if run.avg_lockup_seconds is not none %}{{ '%.1f' | format(run.avg_lockup_seconds / 86400) }} d{% else %}—{% endif %}
    </td>
    <td style="font-family: -apple-system, sans-serif; color: #6b7280;">Max lockup</td>
    <td class="r">
      {% if run.max_lockup_seconds is not none %}{{ '%.1f' | format(run.max_lockup_seconds / 86400) }} d{% else %}—{% endif %}
    </td>
  </tr>
</table>
{% endif %}
{% endif %}

{# ── Portfolio correlation heatmap ─────────────────────────────── #}
{% if portfolio %}
<h2>Portfolio correlation ({{ portfolio.window_days or 30 }}-day window)</h2>
<div class="metric-grid" style="grid-template-columns: 1fr 1fr 1fr;">
  <div class="metric">
    <div class="l">Diversification</div>
    <div class="v {% if (portfolio.summary.get('diversification_ratio') or 0) >= 0.7 %}pos{% elif (portfolio.summary.get('diversification_ratio') or 0) < 0.4 %}neg{% endif %}">
      {{ '%.0f' | format((portfolio.summary.get('diversification_ratio') or 0) * 100) }}%
    </div>
    <div class="sub">higher = less concentrated risk</div>
  </div>
  <div class="metric">
    <div class="l">Mean |ρ|</div>
    <div class="v {% if (portfolio.summary.get('mean_abs_pairwise_correlation') or 0) >= 0.5 %}neg{% elif (portfolio.summary.get('mean_abs_pairwise_correlation') or 0) < 0.3 %}pos{% endif %}">
      {{ '%.2f' | format(portfolio.summary.get('mean_abs_pairwise_correlation') or 0) }}
    </div>
    <div class="sub">
      min {{ '%.2f' | format(portfolio.summary.get('min_pairwise_correlation') or 0) }} ·
      max {{ '%.2f' | format(portfolio.summary.get('max_pairwise_correlation') or 0) }}
    </div>
  </div>
  <div class="metric">
    <div class="l">Strategies</div>
    <div class="v">{{ portfolio.summary.get('n_strategies', 0) }}</div>
    <div class="sub">{{ portfolio.summary.get('n_days', 0) }} days of PnL</div>
  </div>
</div>
{% if portfolio.matrix %}
<h3>Pairwise correlation</h3>
<table class="corr-table">
  <thead>
    <tr>
      <th></th>
      {% for s in portfolio.strategies %}
      <th title="{{ s }}">{{ s[:8] }}</th>
      {% endfor %}
    </tr>
  </thead>
  <tbody>
    {% for row_strat in portfolio.strategies %}
    <tr>
      <th style="text-align: right; padding-right: 4pt;" title="{{ row_strat }}">{{ row_strat[:10] }}</th>
      {% for j in range(portfolio.strategies | length) %}
        {% set _r = portfolio.matrix[loop.index0][j] if (portfolio.matrix | length) > loop.index0 else 0 %}
        {% if _r is none %}{% set _r = 0 %}{% endif %}
        {% set _bg =
          'rgba(239, 68, 68, 0.7)' if _r >= 0.7 else
          'rgba(249, 115, 22, 0.5)' if _r >= 0.4 else
          'rgba(245, 158, 11, 0.35)' if _r >= 0.1 else
          'rgba(120, 120, 120, 0.18)' if _r >= -0.1 else
          'rgba(34, 197, 94, 0.35)' if _r >= -0.4 else
          'rgba(34, 197, 94, 0.55)' if _r >= -0.7 else
          'rgba(34, 197, 94, 0.75)' %}
        <td style="background: {{ _bg }};">{{ '%.2f' | format(_r) }}</td>
      {% endfor %}
    </tr>
    {% endfor %}
  </tbody>
</table>
<p style="font-size: 7.5pt; color: #9ca3af; margin-top: 4pt;">
  Red = high positive correlation (concentrated risk).
  Green = negative correlation (natural hedge).
</p>
{% endif %}
{% endif %}

{# ── Drift monitor (live vs backtest) ─────────────────────────── #}
{% if drift %}
<h2>Drift monitor ({{ drift.window_days or 30 }}-day window)</h2>
<div class="metric-grid">
  {% set _by = drift.summary.get('by_severity') or {} %}
  <div class="drift-tile stable">
    <div class="l">Stable</div>
    <div class="v">{{ _by.get('stable', 0) }}</div>
  </div>
  <div class="drift-tile improved">
    <div class="l">Improved</div>
    <div class="v">{{ _by.get('improved', 0) }}</div>
  </div>
  <div class="drift-tile degraded">
    <div class="l">Degraded</div>
    <div class="v">{{ _by.get('degraded', 0) }}</div>
  </div>
  <div class="drift-tile stale">
    <div class="l">Stale</div>
    <div class="v">{{ _by.get('stale', 0) }}</div>
  </div>
</div>
{% if drift.summary.get('worst_offender') %}
<p style="font-size: 9pt; margin-top: 6pt; padding: 6pt 8pt;
          background: #fef2f2; color: #991b1b; border-radius: 4pt;">
  <strong>Worst offender:</strong>
  <span style="font-family: 'SF Mono', monospace;">{{ drift.summary.worst_offender.get('strategy_slug') }}</span>
  — {{ drift.summary.worst_offender.get('reason') }}
</p>
{% endif %}
{% if drift.strategies %}
<h3>Strategy-by-strategy</h3>
<table class="data-table">
  <thead>
    <tr>
      <th>Strategy</th>
      <th class="r">BT SR</th>
      <th class="r">Live SR</th>
      <th class="r">Δ</th>
      <th class="r">Live PnL</th>
      <th class="r">Live trades</th>
      <th>Severity</th>
    </tr>
  </thead>
  <tbody>
    {% for s in drift.strategies %}
    <tr>
      <td>{{ s.strategy_slug }}</td>
      <td class="r">{% if s.backtest_sharpe is not none %}{{ '%.2f' | format(s.backtest_sharpe) }}{% else %}—{% endif %}</td>
      <td class="r">{% if s.live_sharpe is not none %}{{ '%.2f' | format(s.live_sharpe) }}{% else %}—{% endif %}</td>
      <td class="r {% if (s.sharpe_delta or 0) < -0.5 %}neg{% elif (s.sharpe_delta or 0) > 0.5 %}pos{% endif %}">
        {% if s.sharpe_delta is not none %}
          {{ '%+.2f' | format(s.sharpe_delta) }}
        {% else %}—{% endif %}
      </td>
      <td class="r">{{ (s.live_total_pnl_usd or 0) | money_compact }}</td>
      <td class="r">{{ s.live_trade_count or 0 }}</td>
      <td style="font-family: -apple-system, sans-serif; font-size: 7.5pt;
                 text-transform: uppercase; letter-spacing: 0.05em;
                 {% if s.severity == 'stable' %}color: #047857;
                 {% elif s.severity == 'improved' %}color: #0369a1;
                 {% elif s.severity == 'degraded' %}color: #b91c1c;
                 {% else %}color: #6b7280;{% endif %}">
        {{ s.severity }}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
{% endif %}

{# ════════════════ DIAGNOSTICS ══════════════════════════════════ #}

{# ── Trade-vs-cancel decomposition ─────────────────────────────── #}
{% if run.decomp_trade_count is not none %}
<h2>Trade vs cancel decomposition ({{ run.decomp_window_hours or 24 }}h window)</h2>
<div class="metric-grid" style="grid-template-columns: 1fr 1fr;">
  <div class="metric">
    <div class="l">Trades</div>
    <div class="v pos">{{ '{:,}'.format(run.decomp_trade_count or 0) }}</div>
    <div class="sub">
      {% if run.decomp_trade_count_pct is not none %}{{ '%.1f' | format(run.decomp_trade_count_pct) }}% of book events{% endif %}
    </div>
  </div>
  <div class="metric">
    <div class="l">Cancels</div>
    <div class="v {% if (run.decomp_trade_count_pct or 100) < 30 %}neg{% endif %}">
      {{ '{:,}'.format(run.decomp_cancel_count or 0) }}
    </div>
    <div class="sub">
      {% if run.decomp_trade_count_pct is not none %}{{ '%.1f' | format(100 - run.decomp_trade_count_pct) }}% of book events{% endif %}
    </div>
  </div>
</div>
<p style="font-size: 8.5pt; color: #6b7280; margin-top: 4pt;">
  High cancel rates ⇒ liquidity is thin: most book changes are makers
  pulling, not trades printing.  The fill model accounts for this via
  the cancel-rate covariate when computing fill probabilities.
</p>
{% endif %}

{# ── Empirical constants ──────────────────────────────────────── #}
{% if run.empirical_values %}
<h2>Empirical constants
  <span style="font-size: 8pt; font-weight: 400; letter-spacing: 0;
               text-transform: none; color: {% if run.empirical_measured %}#047857{% else %}#92400e{% endif %};">
    {% if run.empirical_measured %}measured{% else %}defaults{% endif %}
  </span>
</h2>
<p style="font-size: 8.5pt; color: #6b7280; margin: -4pt 0 4pt;">
  Per-platform constants (gas, slippage thresholds, latency floor)
  used by the fill simulator.  ``measured`` = collected from live data;
  ``defaults`` = fall-back when no samples have been observed yet.
  {% if run.empirical_sample_count %}
    Sample size: {{ '{:,}'.format(run.empirical_sample_count) }}.
  {% endif %}
</p>
<table class="data-table">
  <thead><tr><th>Constant</th><th class="r">Value</th></tr></thead>
  <tbody>
    {% for k, v in run.empirical_values.items() %}
    <tr>
      <td style="font-family: -apple-system, sans-serif;">{{ k | replace('_', ' ') }}</td>
      <td class="r">{{ '%.3f' | format(v) if v is number else v }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{# ── Runtime error (if any) ──────────────────────────────────── #}
{% if run.runtime_error %}
<h2>Runtime error</h2>
<pre style="font-family: 'SF Mono', monospace; font-size: 8.5pt;
            color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca;
            border-radius: 4pt; padding: 8pt; white-space: pre-wrap;
            word-wrap: break-word;">{{ run.runtime_error }}</pre>
{% endif %}

<div class="footnote">
  Generated {{ generated_at | humanize_dt }} · Homerun Backtest Studio
</div>

</body>
</html>
