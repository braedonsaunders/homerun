# Homerun headless / docker-compose deployment.
#
# Copy this file to ``.env`` and fill in the values you need:
#   cp .env.example .env
#
# Only ``APP_SECRETS_KEY`` is required to start the stack; everything
# else is either optional (no live trading, no Telegram alerts, etc.)
# or has a sensible default in backend/config.py.  Most of the ~200
# tunables in config.py are exposed in the UI under Settings — only
# the secrets and infra-level knobs live here.
#
# This file is consumed by docker-compose.yml.  The desktop launchers
# (scripts/launchers/Homerun.bat / .command / .desktop) ignore it.

# ----------------------------------------------------------------------
# Image tag — controls which GHCR build the compose stack pulls.
# Use ``latest`` for the tip of main, or pin a release tag like ``v1.2.3``.
# ----------------------------------------------------------------------
HOMERUN_IMAGE_TAG=latest

# ----------------------------------------------------------------------
# Host port bindings (loopback only by default — open to the LAN by
# editing docker-compose.yml directly if you understand the risk).
# ----------------------------------------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ----------------------------------------------------------------------
# Postgres credentials.  These are local-only by default; change them
# if you expose Postgres beyond loopback.
# ----------------------------------------------------------------------
POSTGRES_DB=homerun
POSTGRES_USER=homerun
POSTGRES_PASSWORD=homerun

# ----------------------------------------------------------------------
# Required: secrets-encryption key used by backend/utils/secrets.py to
# encrypt API keys and wallet credentials at rest in the database.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Losing this key means losing access to anything encrypted with it.
# ----------------------------------------------------------------------
APP_SECRETS_KEY=

# ----------------------------------------------------------------------
# Optional: Hugging Face token.  Only needed if you hit HF rate limits
# pulling the sentence-transformer / embedding models on first boot.
# ----------------------------------------------------------------------
HF_TOKEN=

# ----------------------------------------------------------------------
# Optional: Polymarket live-trading credentials.  Leave blank for
# shadow / backtest only.  See docs/ or the in-app Settings → Wallet
# page for guidance on signature types and proxy wallets.
# ----------------------------------------------------------------------
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER=
POLYMARKET_BUILDER_CODE=

# ----------------------------------------------------------------------
# Optional: Polygon RPC endpoints.  Defaults work; override if you
# have a private RPC (e.g. Alchemy, QuickNode) for higher throughput.
# ----------------------------------------------------------------------
POLYGON_RPC_URL=
POLYGON_WS_URL=

# ----------------------------------------------------------------------
# Optional: Telegram alert bot.  Leave blank to disable notifications.
# ----------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----------------------------------------------------------------------
# Logging.  ``DEBUG`` is very verbose — fine for first-boot debugging,
# but the worker planes write a lot at that level.
# ----------------------------------------------------------------------
LOG_LEVEL=INFO
